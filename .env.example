# Application
APP_ENV=development
APP_NAME=SubPilot
APP_PORT=18080

# Backend
API_PREFIX=/api/v1
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=subpilot
POSTGRES_USER=subpilot
POSTGRES_PASSWORD=change-me
POSTGRES_SSL_MODE=disable

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=24h

# Web
VITE_API_BASE_URL=http://localhost:18080/api/v1
